<?xml version="1.0" encoding="utf-8"?>
<!--
  Native AOT single-file executable for Linux ARM64 (Raspberry Pi 4+, AWS Graviton, GitHub Releases).
  No .NET runtime required on the target machine.

  dotnet publish src/Lorex /p:PublishProfile=linux-arm64 -c Release
-->
<Project>
  <PropertyGroup>
    <PublishAot>true</PublishAot>
    <RuntimeIdentifier>linux-arm64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <Configuration>Release</Configuration>
    <StripSymbols>true</StripSymbols>
  </PropertyGroup>
</Project>
