<?xml version="1.0" encoding="utf-8"?>
<!--
  Native AOT single-file executable for Windows ARM64 (Surface Pro X, Snapdragon laptops, GitHub Releases).
  No .NET runtime required on the target machine.

  dotnet publish src/Lorex /p:PublishProfile=win-arm64 -c Release
-->
<Project>
  <PropertyGroup>
    <PublishAot>true</PublishAot>
    <RuntimeIdentifier>win-arm64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <Configuration>Release</Configuration>
    <StripSymbols>true</StripSymbols>
  </PropertyGroup>
</Project>
